<UserControl x:Class="LibraryManagement.Views.Librarian_UserController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LibraryManagement.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<Border Grid.Row="0" Background="#2C3E50" Padding="10">
			<StackPanel>
				<TextBlock x:Name="WelcomeTextBlock" Text="Librarian Dashboard"
                           Foreground="White" FontSize="20" FontWeight="Bold"/>
				<TextBlock x:Name="LibrarianInfoTextBlock"
                           Text="Welcome, Librarian"
                           Foreground="#ECF0F1" FontSize="14"/>
			</StackPanel>
		</Border>
		<Grid Grid.Row="1" Margin="10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="200"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0" Margin="5">
				<Button x:Name="IssueBookButton" Content="Issue Book"
                        Height="40" Margin="0,5" Click="IssueBookButton_Click"/>
				<Button x:Name="ReturnBookButton" Content="Return Book"
                        Height="40" Margin="0,5" Click="ReturnBookButton_Click"/>
				<Button x:Name="ManageInventoryButton" Content="Manage Inventory"
                        Height="40" Margin="0,5" Click="ManageInventoryButton_Click"/>
				<Button x:Name="ViewMembersButton" Content="View Members"
                        Height="40" Margin="0,5" Click="ViewMembersButton_Click"/>
				<Button x:Name="SearchBooksButton" Content="Search Books"
                        Height="40" Margin="0,5" Click="SearchBooksButton_Click"/>
			</StackPanel>
			<Border Grid.Column="1" Background="#F5F5F5" CornerRadius="5" Padding="10">
				<TextBlock Text="Select an option from the menu to get started"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="16" Foreground="#7F8C8D"/>
			</Border>
		</Grid>
	</Grid>
</UserControl>
