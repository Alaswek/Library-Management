<Window x:Class="LibraryManagement.Views.LoginAppl_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vmdtc="clr-namespace:LibraryManagement.ViewModels"
        mc:Ignorable="d"
        Title="LoginAppl_Window" 
        Height="450" Width="700" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Window.DataContext>
        <vmdtc:Login_ViewModel/>
    </Window.DataContext>

    <Grid MouseDown="Border_MouseDown">
        <Border Background="White" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                CornerRadius="20" 
                Width="550" 
                Height="Auto" 
                Padding="0,0,0,30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="15,10,15,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button x:Name="btnMinimize" Width="35" Height="35" Background="Transparent" BorderThickness="0" Click="btnMinimize_Click">
                            <Rectangle Width="12" Height="2" Fill="#333" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <Button x:Name="btnMaximize" Content="☐" Width="35" Height="35" Background="Transparent" Foreground="#333" BorderThickness="0" Click="btnMaximize_Click" VerticalContentAlignment="Center" FontSize="16"/>

                        <Button x:Name="btnClose" Content="✕" Width="35" Height="35" Background="Transparent" Foreground="#333" BorderThickness="0" Click="btnClose_Click" VerticalContentAlignment="Center" FontSize="16"/>
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="60,10,60,10">
                    <TextBlock Text="Login" 
                               FontSize="45" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,10,0,30" 
                               Foreground="#4A90E2"/>

                    <TextBlock Text="Username" Margin="0,0,0,5" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="usernameBox" 
                             Height="40" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             VerticalContentAlignment="Center" 
                             Padding="12,0" 
                             Margin="0,0,0,20"/>

                    <TextBlock Text="Password" Margin="0,0,0,5" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="passBox" 
                             Height="40" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             VerticalContentAlignment="Center" 
                             Padding="12,0" 
                             Margin="0,0,0,30"/>
                    <TextBlock Text="{Binding Show_ErrorMessage, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                               HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                               FontSize="9" FontWeight="SemiBold" Foreground="Red"/>

                    <Button Content="LOGIN" 
                            Background="#4A90E2" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Height="45" 
                            Width="160" 
                            HorizontalAlignment="Right" 
                            Cursor="Hand"
                            Command="{Binding Login_command}"
                            >
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
